---
import Navbar from "../components/Navbar.astro";
import PremiumFooter from "../components/PremiumFooter.astro";
import "../styles/global.css";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 – Page Not Found | Cipher Law</title>
    <script is:inline>
      const path = window.location.pathname;
      const search = window.location.search;
      const hash = window.location.hash;
      const hasFileExtension = /\.[^/]+$/.test(path);
      const legacyBase = "/cipher-law";

      if (path === legacyBase || path.startsWith(`${legacyBase}/`)) {
        const stripped = path.slice(legacyBase.length) || "/";
        window.location.replace(`${stripped}${search}${hash}`);
      } else if (!path.endsWith("/") && !hasFileExtension) {
        window.location.replace(`${path}/${search}${hash}`);
      }
    </script>
  </head>
  <body>
    <Navbar brandName="Cipher Law" lang="en" />

    <section class="not-found-section">
      <div class="not-found-content">
        <div class="error-code gradient-text">404</div>
        <h1 class="error-title">Page Not Found</h1>
        <p class="error-description">
          The page you are looking for does not exist or has been moved.
        </p>
        <div class="error-actions">
          <a href={`${base}/en/`} class="btn btn-primary">Go to Homepage</a>
        </div>
      </div>
    </section>

    <PremiumFooter
      brandName="Cipher Law"
      brandDescription="A markdown-first directory of legal professionals in Bangladesh."
      lang="en"
    />
  </body>
</html>

<style>
  .not-found-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at top, rgba(197, 163, 103, 0.15), transparent 70%),
                linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    padding: 140px 20px 80px;
  }

  .not-found-content {
    text-align: center;
    max-width: 600px;
  }

  .error-code {
    font-size: clamp(80px, 20vw, 160px);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 16px;
  }

  .error-title {
    font-size: clamp(24px, 5vw, 40px);
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .error-description {
    font-size: 17px;
    color: var(--text-muted);
    margin-bottom: 40px;
    line-height: 1.8;
  }

  .error-actions {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
