---
interface Credential {
  icon?: string;
  title: string;
  detail?: string;
}

interface Props {
  credentials: Credential[];
}

const { credentials } = Astro.props;

const iconMap: Record<string, string> = {
  "LL.M": "🎓",
  "LL.B": "🎓",
  "Master": "🎓",
  "Bachelor": "🎓",
  "Supreme Court": "⚖️",
  "High Court": "⚖️",
  "Bar Council": "📜",
  "Enrollment": "📜",
  "IBA": "🌐",
  "International": "🌐",
  "Member": "🏅"
};

const getEmoji = (cred: Credential): string => {
  if (cred.icon) return cred.icon;
  for (const [key, emoji] of Object.entries(iconMap)) {
    if (cred.title.includes(key)) return emoji;
  }
  return "🏅";
};
---

{credentials.length > 0 && (
  <div class="credentials-grid">
    {credentials.map((cred) => (
      <div class="credential-card">
        <div class="credential-badge">{getEmoji(cred)}</div>
        <h3 class="credential-title">{cred.title}</h3>
        {cred.detail && (
          <p class="credential-detail" set:html={cred.detail.replace(/\|/g, '<br>')} />
        )}
      </div>
    ))}
  </div>
)}
