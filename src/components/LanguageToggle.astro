---
import { getCollection } from "astro:content";
import type { Lang } from "../i18n/strings";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const normalizedPath = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length)
  : Astro.url.pathname;
const segments = normalizedPath.split("/").filter(Boolean);
const currentLang = (segments[0] === "bn" ? "bn" : "en") as Lang;
const otherLang: Lang = currentLang === "bn" ? "en" : "bn";
const typeSegment = segments[1];
const slug = segments[2];

const typeMap: Record<string, "advocate" | "chamber" | "firm"> = {
  a: "advocate",
  c: "chamber",
  f: "firm"
};

const collectionName = (targetLang: Lang, seg?: string) => {
  const type = seg ? typeMap[seg] : undefined;
  if (!type) return null;
  const suffix = type === "advocate" ? "advocates" : type === "chamber" ? "chambers" : "firms";
  return `${targetLang}_${suffix}`;
};

let hasCounterpart = false;
const targetCollection = collectionName(otherLang, typeSegment);
if (targetCollection && slug) {
  const entries = await getCollection(targetCollection as any);
  hasCounterpart = entries.some((entry) => entry.slug === slug);
}

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const target = hasCounterpart && typeSegment && slug
  ? `${base}/${otherLang}/${typeSegment}/${slug}/`
  : `${base}/${otherLang}/`;
const label = otherLang === "bn" ? "বাংলা" : "English";
---
<a href={target} aria-label={`Switch to ${label}`}>{label}</a>
