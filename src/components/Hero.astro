---
interface Props {
  badge?: string;
  title: string;
  tagline?: string;
  subtitle?: string;
  description?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  showGrid?: boolean;
  showScrollIndicator?: boolean;
}

const {
  badge,
  title,
  tagline,
  subtitle,
  description,
  primaryCta,
  secondaryCta,
  showGrid = false,
  showScrollIndicator = false
} = Astro.props;
---

<section class="hero">
  {showGrid && <div class="hero-grid"></div>}
  <div class="hero-content">
    {badge && (
      <div class="hero-badge">
        <span class="badge-dot"></span>
        {badge}
      </div>
    )}
    <h1 class="gradient-text" set:html={title.replace(/\n/g, '<br>')} />
    {tagline && <p class="hero-tagline">{tagline}</p>}
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    {description && <p class="hero-description">{description}</p>}
    {(primaryCta || secondaryCta) && (
      <div class="hero-cta">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn-primary">{primaryCta.label}</a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-outline">{secondaryCta.label}</a>
        )}
      </div>
    )}
  </div>
  {showScrollIndicator && <div class="scroll-indicator"></div>}
</section>

<style>
  .hero-tagline {
    font-size: clamp(18px, 3vw, 24px);
    color: var(--accent);
    margin-bottom: 20px;
    font-weight: 300;
    letter-spacing: 3px;
    font-style: italic;
  }
</style>
